{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(.specify/scripts/powershell/check-prerequisites.ps1 -Json -RequireTasks -IncludeTasks)",
      "Bash(powershell -ExecutionPolicy Bypass -File:*)",
      "Skill(document-skills:xlsx)",
      "Skill(document-skills:xlsx:*)",
      "Bash(python:*)",
      "Bash(git fetch:*)",
      "Bash(npx create-next-app:*)",
      "Bash(npm install:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git remote add:*)",
      "Bash(git push:*)",
      "Bash(npm run build:*)",
      "Bash(npm cache clean:*)",
      "Bash(if exist node_modules rmdir /s /q node_modules)",
      "Bash(test:*)",
      "Bash(node -e:*)",
      "Bash(node test-hash.mjs:*)",
      "Bash(del test-hash.mjs)",
      "Bash(cat:*)",
      "Bash(node scripts/generate-password-hash.mjs:*)",
      "Bash(npm run dev:*)",
      "Bash(vercel env:*)",
      "Bash(npm run lint:*)",
      "Bash(if [ -d \"node_modules\" ])",
      "Bash(then echo \"node_modules exists\")",
      "Bash(else echo \"node_modules not found\")",
      "Bash(fi)",
      "Bash(npx next lint:*)",
      "Bash(npx eslint:*)",
      "Bash(git restore:*)",
      "Bash(npm run type-check:*)",
      "Bash(git rm:*)",
      "Bash(npm run db:generate:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(gh pr list:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "alwaysThinkingEnabled": true
}

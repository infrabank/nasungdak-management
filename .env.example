# =====================
# Database (Vercel Postgres)
# =====================
POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_USER="..."
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="..."

# =====================
# Authentication
# =====================
# 레거시 모드: 단일 비밀번호 (AUTH_MODE=legacy)
# 새 모드: 사용자 계정 (AUTH_MODE=users)
AUTH_MODE="legacy"

# bcrypt hash for password "1" - change this in production!
# Generated with: bcrypt.hash('1', 10)
AUTH_PASSWORD_HASH="$2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi"

# Session secret key - change this in production!
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-this-to-a-random-secret-in-production"

# =====================
# Sentry (Error Tracking)
# =====================
# Get from https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =====================
# Logging
# =====================
# debug, info, warn, error
LOG_LEVEL="info"

# =====================
# Kakao Bizmessage (알림톡)
# =====================
KAKAO_REST_API_KEY=""
KAKAO_SENDER_KEY=""

# =====================
# Rate Limiting (Optional - Upstash Redis)
# =====================
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# =====================
# Stripe (Payment)
# =====================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_BASIC_MONTHLY=""
STRIPE_PRICE_BASIC_YEARLY=""
STRIPE_PRICE_STANDARD_MONTHLY=""
STRIPE_PRICE_STANDARD_YEARLY=""
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_PRICE_PREMIUM_YEARLY=""

# =====================
# Feature Flags (Future)
# =====================
# FEATURE_INVENTORY=true
# FEATURE_ALERTS=true
# FEATURE_ANALYTICS=true
